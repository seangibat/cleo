#!/usr/bin/env python3
"""Generate an image via Gemini API. Prints the output file path."""
import base64, json, os, sys, uuid
import requests

def load_gemini_key():
    for path in [
        os.path.expanduser("~/.cleo/workspace/private/gemini.json"),
        os.path.expanduser("~/.config/cleo/gemini.json"),
    ]:
        try:
            with open(path) as f:
                return json.load(f).get("api_key")
        except (FileNotFoundError, json.JSONDecodeError):
            continue
    return None

def main():
    if len(sys.argv) < 2:
        print("Usage: generate-image <prompt>", file=sys.stderr)
        sys.exit(1)

    prompt = " ".join(sys.argv[1:])
    api_key = load_gemini_key()
    if not api_key:
        print("Error: no Gemini API key found", file=sys.stderr)
        sys.exit(1)

    url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-image-preview:generateContent"
    resp = requests.post(url, headers={
        "Content-Type": "application/json",
        "x-goog-api-key": api_key,
    }, json={
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {"responseModalities": ["TEXT", "IMAGE"]},
    }, timeout=60)
    resp.raise_for_status()

    parts = resp.json()["candidates"][0]["content"]["parts"]
    for part in parts:
        inline = part.get("inlineData")
        if inline and inline.get("data"):
            mime = inline.get("mimeType", "image/png")
            ext = {"image/jpeg": ".jpg", "image/webp": ".webp", "image/gif": ".gif"}.get(mime, ".png")
            out = f"/tmp/cleo-img-{uuid.uuid4()}{ext}"
            with open(out, "wb") as f:
                f.write(base64.b64decode(inline["data"]))
            print(out)
            return

    print("Error: no image in response", file=sys.stderr)
    sys.exit(1)

if __name__ == "__main__":
    main()
