#!/usr/bin/env python3
"""Generate speech via Inworld TTS. Prints the output file path.
Usage: generate-voice <text> [--voice Luna]
"""
import base64, json, os, subprocess, sys, uuid
import requests

def load_config():
    for path in [
        os.path.expanduser("~/.cleo/workspace/private/inworld.json"),
        os.path.expanduser("~/.config/cleo/inworld.json"),
    ]:
        try:
            with open(path) as f:
                data = json.load(f)
            if data.get("api_key"):
                data.setdefault("voice", "Luna")
                return data
        except (FileNotFoundError, json.JSONDecodeError):
            continue
    return None

def main():
    if len(sys.argv) < 2:
        print("Usage: generate-voice <text> [--voice Luna]", file=sys.stderr)
        sys.exit(1)

    # Parse args
    voice = None
    text_parts = []
    i = 1
    while i < len(sys.argv):
        if sys.argv[i] == "--voice" and i + 1 < len(sys.argv):
            voice = sys.argv[i + 1]
            i += 2
        else:
            text_parts.append(sys.argv[i])
            i += 1

    text = " ".join(text_parts)
    if not text:
        print("Error: no text provided", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    if not config:
        print("Error: no Inworld API key found", file=sys.stderr)
        sys.exit(1)

    voice = voice or config.get("voice", "Luna")
    api_key = config["api_key"]

    resp = requests.post(
        "https://api.inworld.ai/tts/v1/voice",
        headers={
            "Authorization": f"Basic {api_key}",
            "Content-Type": "application/json",
        },
        json={
            "text": text,
            "voiceId": voice,
            "modelId": "inworld-tts-1.5-max",
            "speaking_rate": config.get("speaking_rate", 2.3),
        },
        timeout=30,
    )
    resp.raise_for_status()

    audio_b64 = resp.json().get("audioContent")
    if not audio_b64:
        print("Error: no audio in response", file=sys.stderr)
        sys.exit(1)

    file_id = uuid.uuid4()
    raw_path = f"/tmp/cleo-voice-{file_id}-raw.mp3"
    mp3_path = f"/tmp/cleo-voice-{file_id}.mp3"

    with open(raw_path, "wb") as f:
        f.write(base64.b64decode(audio_b64))

    # Post-process: speed up + pitch down + ethereal chorus + small room reverb
    try:
        subprocess.run(
            [
                "ffmpeg", "-y", "-i", raw_path,
                "-af", "atempo=1.3,asetrate=44100*0.96,aresample=44100,chorus=0.7:0.9:45|55:0.35|0.25:0.3|0.2:2|2.5,aecho=0.8:0.75:15|25:0.12|0.06",
                mp3_path,
            ],
            capture_output=True, check=True,
        )
        os.unlink(raw_path)
    except subprocess.CalledProcessError:
        os.rename(raw_path, mp3_path)

    print(mp3_path)

if __name__ == "__main__":
    main()
