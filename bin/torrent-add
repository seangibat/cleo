#!/usr/bin/env python3
"""Download a torrent by ID. Usage: torrent-add <id> --filename <name> --dest <path>"""
import os, subprocess, sys

SCRIPT = os.path.expanduser("~/.cleo/workspace/scripts/download.py")

def main():
    if len(sys.argv) < 2:
        print("Usage: torrent-add <id> --filename <name> --dest <path>", file=sys.stderr)
        sys.exit(1)

    args = ["python3", SCRIPT, "--download-id"] + sys.argv[1:]
    result = subprocess.run(args, capture_output=True, text=True, timeout=60)
    print(result.stdout + result.stderr)
    sys.exit(result.returncode)

if __name__ == "__main__":
    main()
